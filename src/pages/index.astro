---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SERIES, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf(),
);
const sections = SERIES.map((series) => ({
	...series,
	posts: posts.filter((p) => p.data.series === series.id),
}));
const unsorted = posts.filter((p) => !SERIES.some((s) => s.id === p.data.series));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="home">
			<section class="intro">
				<p>
					Where mindful reflection and design-driven thinking synthesize meaning and reveal the next
					self-crafted &ldquo;stepping stones&rdquo; on my continuous journey to discover
					novelty&hellip;
				</p>
			</section>
			<section class="image-band">
				<img src="/images/home.webp" alt="" />
			</section>
			{
				sections.map((series) => (
					<section class="lane">
						<div class="series-heading">
							<h4>
								<a href={`/${series.id}/`}>{series.title}</a>
							</h4>
							<p class="series-description">{series.description}</p>
						</div>
						<ul class="post-list">
							{series.posts.map((post) => (
								<li>
									<a href={`/blog/${post.id}/`}>{post.data.title}</a>
									<span class="date">
										{post.data.pubDate.toLocaleDateString('en-US', { month: 'short' })}{' '}
										{post.data.pubDate.getFullYear()}
									</span>
								</li>
							))}
						</ul>
					</section>
				))
			}
			{
				unsorted.length > 0 && (
					<section class="lane">
						<h4>Other Writing</h4>
						<ul class="post-list">
							{unsorted.map((post) => (
								<li>
									<a href={`/blog/${post.id}/`}>{post.data.title}</a>
									<span class="date">
										{post.data.pubDate.toLocaleDateString('en-US', { month: 'short' })}{' '}
										{post.data.pubDate.getFullYear()}
									</span>
								</li>
							))}
						</ul>
					</section>
				)
			}
		</main>
		<Footer />
	</body>
</html>

<style>
	main.home {
		width: 100%;
		max-width: 100%;
		margin: 0;
		padding: 0;
	}
	.intro {
		padding: 9em 2.5em;
	}
	.intro p {
		max-width: 48em;
		margin: 0;
	}
	.image-band {
		width: 100%;
		height: 46vw;
		min-height: 320px;
		max-height: 560px;
	}
	.image-band img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: 50% 50%;
		display: block;
		border-radius: 0;
	}
	.lane {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 2em;
		padding: 4em 2.5em;
	}
	.lane h4 {
		margin: 0;
	}
	.lane h4 a {
		color: var(--navy);
		text-decoration: none;
	}
	.lane h4 a:hover {
		text-decoration: underline;
		opacity: 1;
	}
	.series-description {
		margin: 0.6em 0 0 0;
		max-width: 24em;
	}
	.post-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.post-list li {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0.75em;
		align-items: baseline;
		margin-bottom: 1.6em;
	}
	.post-list a {
		font-family: var(--font-syne), 'Syne', sans-serif;
		font-size: 1.45rem;
		letter-spacing: -0.02em;
		color: var(--navy);
		text-decoration: none;
		line-height: 1.17;
	}
	.post-list a:hover {
		text-decoration: underline;
		opacity: 1;
	}
	.post-list .date {
		font-size: 1rem;
	}
	@media (max-width: 720px) {
		.intro {
			padding: 5em 1.5em;
		}
		.lane {
			grid-template-columns: 1fr;
			padding: 3em 1.5em;
		}
	}
</style>
