---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SERIES, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const sections = SERIES.map((series) => ({
	...series,
	posts: posts.filter((p) => p.data.series === series.id),
}));
const currentSections = sections.filter((s) => !s.archived);
const archivedSections = sections.filter((s) => s.archived);
const unsorted = posts.filter((p) => !SERIES.some((s) => s.id === p.data.series));
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="home">
			<section class="intro">
				<p>Silly mental adventures in the search for novelty&hellip;</p>
			</section>
			<section class="image-band">
				<img src="/images/home.webp" alt="" />
			</section>
			{
				currentSections.map((series) => (
					<section class="lane">
						<div class="series-heading">
							<h4>
								<a href={`/${series.id}/`}>{series.title}</a>
							</h4>
							{series.description && <p class="series-description">{series.description}</p>}
						</div>
						<ul class="post-list">
							{series.posts.map((post) => (
								<li>
									<a href={`/blog/${post.id}/`}>{post.data.title}</a>
									<span class="date">
										{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' })}
									</span>
								</li>
							))}
						</ul>
					</section>
				))
			}
			{
				unsorted.length > 0 && (
					<section class="lane">
						<h4>Other Writing</h4>
						<ul class="post-list">
							{unsorted.map((post) => (
								<li>
									<a href={`/blog/${post.id}/`}>{post.data.title}</a>
									<span class="date">
										{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' })}
									</span>
								</li>
							))}
						</ul>
					</section>
				)
			}
			{
				archivedSections.length > 0 && (
					<section class="lane archived">
						<details class="archive">
							<summary>
								<span class="archive-caret" aria-hidden="true" />
								<span class="archive-title">Archived Projects</span>
							</summary>
							<div class="archive-body">
								<p class="series-description">Earlier work, kept for the record.</p>
								<div class="archived-series">
									{archivedSections.map((series) => (
										<div class="archived-item">
											<h5>
												<a href={`/${series.id}/`}>{series.title}</a>
											</h5>
											<ul class="post-list">
												{series.posts.map((post) => (
													<li>
														<a href={`/blog/${post.id}/`}>{post.data.title}</a>
														<span class="date">
															{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' })}
														</span>
													</li>
												))}
											</ul>
										</div>
									))}
								</div>
							</div>
						</details>
					</section>
				)
			}
		</main>
		<Footer />
	</body>
</html>

<style>
	main.home {
		width: 100%;
		max-width: 100%;
		margin: 0;
		padding: 0;
	}
	.intro {
		padding: 6.5em 2.5em;
	}
	.intro p {
		max-width: 48em;
		margin: 0;
	}
	.image-band {
		width: 100%;
		height: 46vw;
		min-height: 320px;
		max-height: 560px;
	}
	.image-band img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: 50% 50%;
		display: block;
		border-radius: 0;
	}
	.lane {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 2em;
		padding: 4em 2.5em;
	}
	.lane h4 {
		margin: 0;
	}
	.lane h4 a {
		color: var(--navy);
		text-decoration: none;
	}
	.lane h4 a:hover {
		text-decoration: underline;
		opacity: 1;
	}
	.series-description {
		margin: 0.6em 0 0 0;
		max-width: 24em;
	}
	.post-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.post-list li {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0.75em;
		align-items: baseline;
		margin-bottom: 1.6em;
	}
	.post-list a {
		font-family: var(--font-syne), 'Syne', sans-serif;
		font-size: 1.45rem;
		letter-spacing: -0.02em;
		color: var(--navy);
		text-decoration: none;
		line-height: 1.17;
	}
	.post-list a:hover {
		text-decoration: underline;
		opacity: 1;
	}
	.post-list .date {
		font-size: 1rem;
	}
	.lane.archived {
		display: block;
		border-top: 1px solid rgba(37, 53, 81, 0.18);
		padding-top: 3em;
	}
	.archive summary {
		display: inline-flex;
		align-items: baseline;
		gap: 0.55em;
		cursor: pointer;
		list-style: none;
		user-select: none;
	}
	.archive summary::-webkit-details-marker {
		display: none;
	}
	.archive-title {
		font-family: var(--font-syne), 'Syne', sans-serif;
		font-size: 1.45rem;
		letter-spacing: -0.02em;
		line-height: 1.15;
		color: var(--muted);
	}
	.archive summary:hover .archive-title {
		text-decoration: underline;
	}
	.archive-caret {
		width: 0;
		height: 0;
		border-left: 0.42em solid var(--muted);
		border-top: 0.3em solid transparent;
		border-bottom: 0.3em solid transparent;
		transform: translateY(-0.08em);
		transition: transform 0.15s ease;
	}
	.archive[open] .archive-caret {
		transform: translateY(-0.08em) rotate(90deg);
	}
	.archive-body {
		margin-top: 1.8em;
	}
	.archived-item h5 {
		margin: 0 0 0.8em 0;
		font-size: 1.45rem;
		letter-spacing: -0.02em;
		color: var(--muted);
	}
	.archived-item h5 a {
		color: var(--muted);
		text-decoration: none;
	}
	.archived-item h5 a:hover {
		text-decoration: underline;
	}
	.lane.archived .post-list a {
		font-size: 1.15rem;
		color: var(--muted);
	}
	@media (max-width: 720px) {
		.intro {
			padding: 4.5em 1.5em;
		}
		.lane {
			grid-template-columns: 1fr;
			padding: 3em 1.5em;
		}
	}
</style>
