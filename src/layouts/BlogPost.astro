---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SERIES } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, series: seriesId, location } = Astro.props;
const series = SERIES.find((s) => s.id === seriesId);
const dateLabel = pubDate.toLocaleDateString('en-US', {
	month: 'short',
	day: 'numeric',
	year: 'numeric',
	timeZone: 'UTC',
});
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			.title {
				margin: 1em 0 2em 0;
			}
			.date {
				margin-top: 0.75em;
			}
			.series-label {
				display: inline-block;
				font-family: var(--font-syne), 'Syne', sans-serif;
				font-size: 1rem;
				letter-spacing: -0.01em;
				color: var(--navy);
				text-decoration: none;
				margin-bottom: 1em;
			}
			.series-label:hover {
				text-decoration: underline;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="title">
					{
						series && (
							<a class="series-label" href={`/${series.id}/`}>
								{series.title}
							</a>
						)
					}
					<h1>{title}</h1>
					<div class="date">{location ? `${dateLabel} · ${location}` : dateLabel}</div>
				</div>
				<slot />
			</article>
		</main>
		<Footer />
	</body>
</html>
