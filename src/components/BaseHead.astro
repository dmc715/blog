---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/blog-placeholder-1.jpg';
import { SITE_TITLE } from '../consts';
import { Font } from 'astro:assets';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image = FallbackImage } = Astro.props;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<Font cssVariable="--font-syne" preload />
<Font cssVariable="--font-pt-serif" preload />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image.src, Astro.url)} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image.src, Astro.url)} />

<!-- Analytics (self-hosted, cookieless): page views + active reading time -->
<script is:inline>
	(function () {
		try {
			if (location.search.indexOf('notrack=1') !== -1) localStorage.setItem('cx-notrack', '1');
			if (localStorage.getItem('cx-notrack') === '1') return;
		} catch (e) {}
		var EP = 'https://chengxueer-analytics.xueercheng.workers.dev/collect';
		var sid =
			self.crypto && crypto.randomUUID
				? crypto.randomUUID()
				: String(Date.now()) + Math.random().toString(16).slice(2);
		var path = location.pathname;
		var active = 0,
			last = Date.now(),
			hidden = document.hidden,
			done = false;
		function flush() {
			var now = Date.now();
			if (!hidden) active += now - last;
			last = now;
		}
		function send(t, sec) {
			try {
				var b = JSON.stringify({
					t: t,
					s: sid,
					p: path,
					r: t === 'pv' ? document.referrer : undefined,
					sec: sec || 0,
				});
				if (navigator.sendBeacon)
					navigator.sendBeacon(EP, new Blob([b], { type: 'text/plain' }));
				else fetch(EP, { method: 'POST', body: b, keepalive: true });
			} catch (e) {}
		}
		send('pv', 0);
		var iv = setInterval(function () {
			flush();
			send('hb', Math.round(active / 1000));
		}, 15000);
		document.addEventListener('visibilitychange', function () {
			flush();
			hidden = document.hidden;
			last = Date.now();
			if (hidden) send('hb', Math.round(active / 1000));
		});
		addEventListener('pagehide', function () {
			if (done) return;
			done = true;
			flush();
			clearInterval(iv);
			send('hb', Math.round(active / 1000));
		});
	})();
</script>
