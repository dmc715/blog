---
import { SITE_TITLE } from '../consts';
---

<header>
	<a class="site-title" href="/">{SITE_TITLE}</a>
</header>
<style>
	header {
		padding: 1.6em 2em;
	}
	.site-title {
		font-family: var(--font-syne), 'Syne', sans-serif;
		font-size: 1.3rem;
		letter-spacing: -0.02em;
		color: var(--navy);
		text-transform: capitalize;
		text-decoration: none;
	}
</style>
